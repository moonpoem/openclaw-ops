DISPLAY_NAME=示例主机
REMOTE_HOST=ops@example-host.local
REMOTE_PATH_PREFIX=export PATH=/opt/homebrew/bin:/usr/local/bin:$PATH;
REMOTE_USER=ops
SSH_IDENTITIES_ONLY=true
SSH_IDENTITY_FILE=~/.ssh/id_ed25519
SSH_CONFIG_PATH=~/.ssh/config
OPENCLAW_REPO_URL=https://github.com/example/openclaw.git
REMOTE_WORKDIR=$HOME/openclaw-src
NPM_GLOBAL_ROOT=/opt/homebrew/lib/node_modules
COMMAND_TIMEOUT_SECONDS=300
GATEWAY_PROBE_TIMEOUT_SECONDS=8

# Optional extra hosts. You can also add/edit hosts directly in the app UI.
# PROFILE_NAMES=staging
# ACTIVE_PROFILE=default
# PROFILE_STAGING_DISPLAY_NAME=预发布环境
# PROFILE_STAGING_REMOTE_HOST=ops@staging.example.com
# PROFILE_STAGING_REMOTE_USER=ops
# PROFILE_STAGING_SSH_IDENTITY_FILE=~/.ssh/id_ed25519
